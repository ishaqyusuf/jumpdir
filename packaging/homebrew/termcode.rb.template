class Termcode < Formula
  desc "Jump into and run scripts for local repos"
  homepage "https://github.com/ishaqyusuf/termcode"
  url "https://github.com/ishaqyusuf/termcode/archive/refs/tags/v0.2.1.tar.gz"
  sha256 "CHANGE_ME_AFTER_TAGGING_RELEASE"
  license "MIT"

  def install
    bin.install "bin/termcode"
  end

  test do
    assert_match "termcode 0.2.1", shell_output("#{bin}/termcode --version")
  end
end
